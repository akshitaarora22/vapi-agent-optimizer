# Vapi API key — get from https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here

# Anthropic API key — used for patient simulator and LLM scorer
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vapi phone number ID to call from (get from Vapi dashboard > Phone Numbers)
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here

# Optional: number to call for testing (leave blank to use web call)
# VAPI_TEST_PHONE_NUMBER=+1234567890

# Optimization settings
N_CALLS_PER_EVAL=5        # calls per configuration evaluation
N_ITERATIONS=6            # GP-BO iterations (plus 3 random init)
MAX_PARALLEL_CALLS=3      # concurrent Vapi calls
CALL_TIMEOUT_SECONDS=120  # max seconds to wait for a call to complete

# Real call validation (Step 2 — after running main.py)
# Your ngrok public URL when running the patient simulator server
NGROK_URL=https://xxxx.ngrok-free.app

# Your Vapi inbound phone number (e.g. +17348080512) — used as the agent side in real call validation
VAPI_AGENT_PHONE_NUMBER=+17348080512
